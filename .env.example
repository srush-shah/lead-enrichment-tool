CENSUS_API_KEY=
WALKSCORE_API_KEY=
NEWSAPI_KEY=
GEMINI_API_KEY=

WEBHOOK_SHARED_SECRET=replace-me-with-random-string

# Web app session auth (Next.js -> backend). Same secret is set as
# NEXTAUTH_SECRET in the Next.js app so issued JWTs verify here.
NEXTAUTH_SECRET=replace-me-with-32plus-byte-random-string
# Comma-separated allowlist for Google OAuth sign-in. Empty = open.
ALLOWED_EMAILS=
# Comma-separated extra CORS origins (e.g. https://your-app.vercel.app).
# localhost:3000 is always allowed.
EXTRA_CORS_ORIGINS=

CACHE_DB_PATH=./cache.db
LOG_LEVEL=INFO

# Optional Postgres connection string for daily_usage persistence on Render
# (whose free dyno wipes the SQLite file on cold start). Leave empty to use
# the local SQLite cache.db. Get this from a Render Postgres instance's
# "Internal Database URL".
DATABASE_URL=
